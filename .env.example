# Copy this file: cp .env.example .env

# HuggingFace cache directory (optional — defaults to ~/.cache/huggingface)
# HF_HOME=/path/to/your/cache

# Override default model names (optional)
# BERT_MODEL_NAME=distilbert-base-uncased
# SUMMARY_MODEL_NAME=sshleifer/distilbart-cnn-6-6

# Set to 1 to disable HuggingFace progress bars in CI
# TRANSFORMERS_VERBOSITY=error
